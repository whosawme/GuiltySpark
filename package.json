{
  "name": "guiltyspark",
  "version": "0.1.0",
  "description": "Local PII privacy layer for LLM prompts via MCP",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:backend": "tsc",
    "build:dashboard": "cd dashboard && npm install && npm run build",
    "dev": "tsx src/index.ts",
    "dev:proxy": "tsx src/proxy-entry.ts",
    "dev:dashboard": "tsx src/dashboard-entry.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "start": "node dist/index.js",
    "start:proxy": "node dist/proxy-entry.js",
    "start:dashboard": "node dist/dashboard-entry.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-yaml": "^4.1.0",
    "ollama": "^0.5.0",
    "ws": "^8.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "jest": "^29.0.0",
    "puppeteer": "^24.40.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
